{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Depurar ejemplo",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/akasha_example",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Habilitar impresión con formato para gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}
