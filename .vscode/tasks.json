{
	"version": "2.0.0",
	"inputs": [
		{
			"id": "selectExample",
			"type": "pickString",
			"description": "Elige qué ejemplo ejecutar",
			"options": [
				"quickstart",
				"error_handling",
				"multiple_datasets",
				"navigation",
				"cleanup",
				"nested_data",
				"benchmarks"
			],
			"default": "quickstart"
		}
	],
	"tasks": [
		{
			"label": "🧹 Limpiar build",
			"type": "shell",
			"command": "rm",
			"args": [
				"-rf",
				"build"
			],
			"group": "build",
			"problemMatcher": [],
			"detail": "Elimina el directorio build completo"
		},
		{
			"label": "⚙️ Configurar proyecto (Conan + CMake)",
			"type": "shell",
			"command": "conan install . --output-folder=build --build=missing -s build_type=Release && cmake -S . -B build -DCMAKE_TOOLCHAIN_FILE=build/conan_toolchain.cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
			"group": "build",
			"problemMatcher": [],
			"dependsOn": [
				"🧹 Limpiar build"
			],
			"detail": "Limpia, instala dependencias con Conan y configura el proyecto con CMake (puede tardar en la primera ejecución)"
		},
		{
			"label": "🔨 Compilar",
			"type": "shell",
			"command": "cmake . -B build > /dev/null 2>&1 && cmake --build build -j",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$gcc",
			"detail": "Compila el proyecto (librería solamente)"
		},
		{
			"label": "🪛 Recompilar",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--clean-first",
				"-j"
			],
			"group": "build",
			"problemMatcher": "$gcc",
			"detail": "Limpia y recompila el proyecto completo"
		},
		{
			"label": "📦 Compilar ejemplos",
			"type": "shell",
			"command": "cmake . -B build -DCMAKE_BUILD_TYPE=Release -DBUILD_EXAMPLE=ON -DCMAKE_TOOLCHAIN_FILE=build/conan_toolchain.cmake && cmake --build build -j",
			"group": "build",
			"problemMatcher": "$gcc",
			"detail": "Compila los 7 ejemplos (CMAKE resetea BUILD_EXAMPLE a OFF después)"
		},
		{
			"label": "🚀 Ejecutar ejemplo",
			"type": "shell",
			"command": "${workspaceFolder}/build/akasha_${input:selectExample}",
			"group": "test",
			"problemMatcher": [],
			"detail": "Selecciona y ejecuta uno de los 7 ejemplos",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			}
		}
	]
}
